      "Bash(./scripts/scan.sh:*)",
      "Bash(scripts/scan.sh:*)",
      "Bash(bash scripts/digest.sh:*)",
      "Bash(bash scripts/check-links.sh:*)",
      "Bash(node scripts/build-report.js:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws configure get:*)",
      "Bash(aws:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(mkdir:*)",
      "Bash(python3:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(date:*)",
      "Bash(basename:*)",
