      "Bash(aws * authorize-*)",
      "Bash(aws * revoke-*)",
      "Bash(aws * cancel-*)",
      "Bash(aws * reset-*)",
      "Bash(aws * restore-*)",
      "Bash(aws * import-*)",
      "Bash(aws * replace-*)",
      "Bash(aws * tag-*)",
      "Bash(aws * untag-*)",
